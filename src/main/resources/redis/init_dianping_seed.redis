DEL seckill:order:1
SET seckill:stock:1 100
GEOADD shop:geo:1 120.149192 30.316078 1
EVAL "for i=2,101 do redis.call('del','seckill:order:'..i); redis.call('set','seckill:stock:'..i,100); local x=120.100000 + (i * 0.0005); local y=30.280000 + (i * 0.0003); redis.call('geoadd','shop:geo:'..i,x,y,tostring(i)); end; return 1" 0
